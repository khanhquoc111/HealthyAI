{
  "disease_info": {
    "id": "gout",
    "name": "Đánh giá Nguy cơ Gout (Thống phong)",
    "version": "1.0",
    "description": "Công cụ đánh giá nguy cơ phát triển bệnh Gout dựa trên các yếu tố nguy cơ chính như acid uric, lối sống và tiền sử gia đình.",
    "author": "LuanVanKTPM",
    "last_updated": "2026-06-02"
  },
  "fields": [
    {
      "key": "age",
      "label": "Tuổi",
      "type": "number",
      "required": true,
      "min": 18,
      "max": 100,
      "unit": "tuổi"
    },
    {
      "key": "gender",
      "label": "Giới tính",
      "type": "select",
      "required": true,
      "options": [
        { "value": "male", "label": "Nam" },
        { "value": "female", "label": "Nữ" }
      ]
    },
    {
      "key": "bmi",
      "label": "Chỉ số khối cơ thể (BMI)",
      "type": "number",
      "required": true,
      "min": 15,
      "max": 50,
      "unit": "kg/m²"
    },
    {
      "key": "family_history_gout",
      "label": "Tiền sử gia đình bị Gout",
      "type": "boolean",
      "required": false
    },
    {
      "key": "alcohol_consumption",
      "label": "Uống rượu bia thường xuyên",
      "type": "select",
      "required": false,
      "options": [
        { "value": "none", "label": "Không uống" },
        { "value": "occasional", "label": "Thỉnh thoảng" },
        { "value": "regular", "label": "Thường xuyên" }
      ]
    },
    {
      "key": "purine_rich_diet",
      "label": "Ăn nhiều thực phẩm giàu purin (thịt đỏ, hải sản)",
      "type": "select",
      "required": false,
      "options": [
        { "value": "low", "label": "Ít" },
        { "value": "moderate", "label": "Trung bình" },
        { "value": "high", "label": "Nhiều" }
      ]
    },
    {
      "key": "hypertension",
      "label": "Có bị tăng huyết áp không?",
      "type": "boolean",
      "required": false
    },
    {
      "key": "exercise_minutes_per_week",
      "label": "Số phút tập thể dục mỗi tuần",
      "type": "number",
      "required": false,
      "min": 0,
      "max": 1000,
      "unit": "phút"
    }
  ],
  "risk_config": {
    "baseline_mapping": [
      {
        "name": "Low Risk",
        "condition": { "field": "bmi", "op": "lt", "value": 25 },
        "score": 20
      },
      {
        "name": "Moderate Risk",
        "condition": { "field": "bmi", "op": "range", "min": 25, "max": 30 },
        "score": 40
      },
      {
        "name": "High Risk",
        "condition": { "field": "bmi", "op": "gte", "value": 30 },
        "score": 55
      }
    ],
    "risk_modifiers": [
      {
        "id": "male_gender",
        "description": "Nam giới (nguy cơ cao hơn nữ)",
        "condition": { "field": "gender", "op": "eq", "value": "male" },
        "effect_type": "multiplicative",
        "value": 1.8,
        "category": "modifier",
        "priority": 30
      },
      {
        "id": "family_history",
        "description": "Có tiền sử gia đình bị Gout",
        "condition": { "field": "family_history_gout", "op": "bool_true" },
        "effect_type": "multiplicative",
        "value": 2.0,
        "category": "modifier",
        "priority": 35
      },
      {
        "id": "regular_alcohol",
        "description": "Uống rượu bia thường xuyên",
        "condition": { "field": "alcohol_consumption", "op": "eq", "value": "regular" },
        "effect_type": "multiplicative",
        "value": 1.6,
        "category": "modifier",
        "priority": 25
      },
      {
        "id": "high_purine_diet",
        "description": "Chế độ ăn giàu purin",
        "condition": { "field": "purine_rich_diet", "op": "eq", "value": "high" },
        "effect_type": "multiplicative",
        "value": 1.5,
        "category": "modifier",
        "priority": 20
      },
      {
        "id": "hypertension",
        "description": "Có tăng huyết áp kèm theo",
        "condition": { "field": "hypertension", "op": "bool_true" },
        "effect_type": "multiplicative",
        "value": 1.4,
        "category": "modifier",
        "priority": 22
      }
    ],
    "protective_factors": [
      {
        "id": "regular_exercise",
        "description": "Tập thể dục đều đặn",
        "condition": { "field": "exercise_minutes_per_week", "op": "gte", "value": 150 },
        "effect_type": "divisive",
        "value": 1.25,
        "category": "protective",
        "priority": 15
      }
    ],
    "interactions": [],
    "thresholds": [
      { "range": [0, 40], "level": "low" },
      { "range": [40, 70], "level": "medium" },
      { "range": [70, 100], "level": "high" }
    ],
    "computed_fields": [
      {
        "key": "lifestyle_score",
        "formula": "bmi * 1.2 + (age > 50 ? 15 : 0)",
        "dependencies": ["bmi", "age"],
        "description": "Điểm lối sống"
      }
    ]
  },
  "explanation_templates": [
    {
      "rule_id": "male_gender",
      "template": "Nam giới có nguy cơ mắc Gout cao hơn nữ giới đáng kể"
    },
    {
      "rule_id": "family_history",
      "template": "Tiền sử gia đình bị Gout - yếu tố di truyền mạnh"
    },
    {
      "rule_id": "regular_alcohol",
      "template": "Uống rượu bia thường xuyên làm tăng nguy cơ tích tụ acid uric"
    },
    {
      "rule_id": "high_purine_diet",
      "template": "Chế độ ăn giàu purin (thịt đỏ, hải sản) làm tăng acid uric máu"
    }
  ],
  "risk_levels": {
    "low": { "summary": "Nguy cơ thấp. Tiếp tục duy trì lối sống lành mạnh." },
    "medium": { "summary": "Nguy cơ trung bình. Nên hạn chế rượu bia và thực phẩm giàu purin." },
    "high": { "summary": "Nguy cơ cao. Khuyến nghị kiểm tra acid uric máu và gặp bác sĩ." }
  },
  "recommendations": [
    {
      "id": "diet_change",
      "condition": { "field": "final_score", "op": "gte", "value": 40 },
      "text": "Giảm thực phẩm giàu purin (thịt đỏ, hải sản), tăng rau củ và uống nhiều nước.",
      "priority": 1,
      "action_type": "lifestyle"
    },
    {
      "id": "alcohol_reduction",
      "condition": { "field": "final_score", "op": "gte", "value": 50 },
      "text": "Hạn chế hoặc bỏ rượu bia để giảm nguy cơ cơn Gout cấp.",
      "priority": 2,
      "action_type": "lifestyle"
    },
    {
      "id": "medical_check",
      "condition": { "field": "final_score", "op": "gte", "value": 70 },
      "text": "Nên đi xét nghiệm acid uric máu và khám chuyên khoa Thấp khớp.",
      "priority": 3,
      "action_type": "referral"
    }
  ]
}