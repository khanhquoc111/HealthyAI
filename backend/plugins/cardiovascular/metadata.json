{
  "disease_info": {
    "id": "cardiovascular",
    "name": "Đánh giá Nguy cơ Bệnh Tim Mạch",
    "version": "1.1",
    "description": "Công cụ đánh giá nguy cơ phát triển bệnh lý tim mạch, nhồi máu cơ tim hoặc đột quỵ.",
    "author": "LuanVanKTPM",
    "last_updated": "2026-06-04"
  },
  "fields": [
    {
      "key": "systolic",
      "label": "Huyết áp tâm thu",
      "type": "number",
      "required": true,
      "min": 70,
      "max": 250,
      "unit": "mmHg"
    },
    {
      "key": "diastolic",
      "label": "Huyết áp tâm trương",
      "type": "number",
      "required": true,
      "min": 40,
      "max": 150,
      "unit": "mmHg"
    },
    {
      "key": "total_cholesterol",
      "label": "Cholesterol toàn phần",
      "type": "number",
      "required": true,
      "min": 100,
      "max": 600,
      "unit": "mg/dL"
    },
    {
      "key": "hdl",
      "label": "Cholesterol HDL (Tốt)",
      "type": "number",
      "required": true,
      "min": 10,
      "max": 150,
      "unit": "mg/dL"
    },
    {
      "key": "alcohol",
      "label": "Tình trạng uống rượu bia",
      "type": "select",
      "required": false,
      "options": [
        { "value": "0", "label": "Không/Hiếm khi" },
        { "value": "1", "label": "Thường xuyên" }
      ]
    }
  ],
  "risk_config": {
    "baseline_mapping": [
      { "name": "Low Risk", "condition": { "field": "systolic", "op": "lt", "value": 130 }, "score": 15 },
      { "name": "Moderate Risk", "condition": { "field": "systolic", "op": "gte", "value": 130 }, "score": 35 },
      { "name": "High Risk", "condition": { "field": "systolic", "op": "gte", "value": 140 }, "score": 55 }
    ],
    "risk_modifiers": [
      {
        "id": "cholesterol_high",
        "description": "Cholesterol toàn phần cao (>240)",
        "condition": { "field": "total_cholesterol", "op": "gte", "value": 240 },
        "effect_type": "multiplicative",
        "value": 1.5,
        "category": "modifier",
        "priority": 20
      },
      {
        "id": "alcohol_abuse",
        "description": "Thường xuyên uống rượu bia",
        "condition": { "field": "alcohol", "op": "eq", "value": "1" },
        "effect_type": "multiplicative",
        "value": 1.3,
        "category": "modifier",
        "priority": 25
      }
    ],
    "protective_factors": [
      {
        "id": "hdl_high",
        "description": "Cholesterol HDL (Tốt) ở mức lý tưởng (>60)",
        "condition": { "field": "hdl", "op": "gte", "value": 60 },
        "effect_type": "divisive",
        "value": 1.2,
        "category": "protective",
        "priority": 10
      }
    ],
    "interactions": [],
    "thresholds": [
      { "range": [0, 40], "level": "low" },
      { "range": [40, 70], "level": "medium" },
      { "range": [70, 100], "level": "high" }
    ]
  },
  "recommendations": [
    {
      "id": "cardio_lifestyle",
      "condition": { "field": "systolic", "op": "gte", "value": 40 },
      "text": "Kiểm soát huyết áp, hạn chế muối trong khẩu phần ăn và tăng cường vận động cơ tim.",
      "priority": 1,
      "action_type": "lifestyle"
    }
  ],
  "cross_validations": [],
  "ml_required_features": [
    "age", "gender_code", "bmi", "systolic", "diastolic",
    "total_cholesterol", "smoke", "exercise", "alcohol"
  ]
}