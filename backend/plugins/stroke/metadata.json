    "protective_factors": [],
    "interactions": [],
    "thresholds": [
      { "range": [0, 29], "level": "low" },
      { "range": [29, 59], "level": "medium" },
      { "range": [59, 100], "level": "high" }
    ]
  },
  "recommendations": [
    {
      "id": "stroke_low",
      "condition": { "field": "final_score", "op": "lt", "value": 30 },
      "text": "Duy trì chế độ ăn uống lành mạnh, tập thể dục thường xuyên và khám sức khỏe định kỳ.",
      "priority": 1,
      "action_type": "lifestyle"
    },
    {
      "id": "stroke_medium",
      "condition": { "field": "final_score", "op": "gte", "value": 30 },
      "text": "Theo dõi huyết áp thường xuyên, hạn chế thuốc lá và rượu bia, tăng cường hoạt động thể chất.",
      "priority": 2,
      "action_type": "monitoring"
    },
    {
      "id": "stroke_high",
      "condition": { "field": "final_score", "op": "gte", "value": 60 },
      "text": "Khám chuyên khoa tim mạch hoặc thần kinh, kiểm soát huyết áp theo hướng dẫn bác sĩ và theo dõi các dấu hiệu cảnh báo đột quỵ.",
      "priority": 3,
      "action_type": "referral"
    }
  ],
