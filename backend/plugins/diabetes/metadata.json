{
  "disease_info": {
    "id": "diabetes",
    "name": "Đánh giá Nguy cơ Tiểu đường Type 2",
    "version": "1.2",
    "description": "Công cụ đánh giá nguy cơ phát triển tiểu đường type 2 dựa trên các yếu tố nguy cơ.",
    "author": "LuanVanKTPM",
    "last_updated": "2026-06-09"
  },
  "fields": [
    {
      "key": "age",
      "label": "Tuổi",
      "type": "number",
      "required": true,
      "min": 18,
      "max": 100,
      "unit": "tuổi"
    },
    {
      "key": "bmi",
      "label": "Chỉ số khối cơ thể (BMI)",
      "type": "number",
      "required": true,
      "min": 15,
      "max": 50,
      "unit": "kg/m²"
    },
    {
      "key": "family_history_diabetes",
      "label": "Tiền sử gia đình bị tiểu đường",
      "type": "boolean",
      "required": false
    },
    {
      "key": "exercise_minutes_per_week",
      "label": "Số phút tập thể dục mỗi tuần",
      "type": "number",
      "required": false,
      "min": 0,
      "max": 1000,
      "unit": "phút"
    },
    {
      "key": "smoking_status",
      "label": "Tình trạng hút thuốc",
      "type": "select",
      "required": false,
      "options": [
        {
          "value": "never",
          "label": "Chưa bao giờ"
        },
        {
          "value": "former",
          "label": "Đã bỏ"
        },
        {
          "value": "current",
          "label": "Đang hút"
        }
      ]
    },
    {
      "key": "hba1c",
      "label": "Chỉ số xét nghiệm HbA1c",
      "type": "number",
      "required": true,
      "min": 3.0,
      "max": 20.0,
      "unit": "%"
    }
  ],
  "risk_config": {
    "baseline_mapping": [
      {
        "name": "Low Risk",
        "condition": {
          "field": "bmi",
          "op": "lt",
          "value": 25
        },
        "score": 15
      },
      {
        "name": "Moderate Risk",
        "condition": {
          "field": "bmi",
          "op": "gte",
          "value": 25
        },
        "score": 35
      },
      {
        "name": "High Risk",
        "condition": {
          "field": "bmi",
          "op": "gte",
          "value": 30
        },
        "score": 55
      }
    ],
    "risk_modifiers": [
      {
        "id": "age_high",
        "description": "Tuổi cao (>45)",
        "condition": {
          "field": "age",
          "op": "gte",
          "value": 45
        },
        "effect_type": "multiplicative",
        "value": 1.4,
        "category": "modifier",
        "priority": 20
      },
      {
        "id": "family_history",
        "description": "Có tiền sử gia đình",
        "condition": {
          "field": "family_history_diabetes",
          "op": "bool_true"
        },
        "effect_type": "multiplicative",
        "value": 1.6,
        "category": "modifier",
        "priority": 25
      },
      {
        "id": "smoking",
        "description": "Đang hút thuốc",
        "condition": {
          "field": "smoking_status",
          "op": "eq",
          "value": "current"
        },
        "effect_type": "multiplicative",
        "value": 1.25,
        "category": "modifier",
        "priority": 15
      }
    ],
    "protective_factors": [
      {
        "id": "regular_exercise",
        "description": "Tập thể dục đều đặn",
        "condition": {
          "field": "exercise_minutes_per_week",
          "op": "gte",
          "value": 150
        },
        "effect_type": "divisive",
        "value": 1.2,
        "category": "protective",
        "priority": 10
      }
    ],
    "interactions": [],
    "thresholds": [
      {
        "range": [
          0,
          40
        ],
        "level": "low"
      },
      {
        "range": [
          40,
          70
        ],
        "level": "medium"
      },
      {
        "range": [
          70,
          100
        ],
        "level": "high"
      }
    ]
  },
  "recommendations": [
    {
      "id": "lifestyle",
      "condition": {
        "field": "final_score",
        "op": "gte",
        "value": 40
      },
      "text": "Tập thể dục ít nhất 150 phút/tuần, giảm cân và ăn uống lành mạnh.",
      "priority": 1,
      "action_type": "lifestyle"
    }
  ],
  "cross_validations": [],
  "ml_required_features": [
    "age", "gender_code", "bmi", "waist",
    "systolic", "diastolic", "hypertension",
    "hba1c", "total_cholesterol", "hdl_cholesterol",
    "smoke", "family_diabetes"
  ]
}