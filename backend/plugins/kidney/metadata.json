{
    "disease_info": {
        "id": "kidney",
        "name": "Đánh giá Nguy cơ Bệnh Thận Mạn (CKD)",
        "version": "1.1",
        "description": "Công cụ đánh giá mức độ suy giảm chức năng thận và rủi ro tiến triển thành bệnh thận mạn tính.",
